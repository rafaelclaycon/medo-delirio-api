# Passwords
SEND_NOTIFICATION_PASSWORD=your-password-here
SET_DONOR_NAMES_PASSWORD=your-password-here
ASSET_OPERATION_PASSWORD=your-password-here
REACTIONS_PASSWORD=your-password-here
DYNAMIC_BANNER_PASSWORD=your-password-here
ANALYTICS_PASSWORD=your-password-here

# APNS (Apple Push Notification Service)
# For the private key, replace actual newlines with \n so it stays on one line.
APNS_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIGH...your-key-here...\n-----END PRIVATE KEY-----
APNS_KEY_IDENTIFIER=your-key-id
APNS_TEAM_IDENTIFIER=your-team-id
APNS_TOPIC=com.yourcompany.YourApp
